# ==============================================================================
# MediFlow (.env.example)
#
# What this file is:
# - A committed template listing every environment variable the MediFlow stack
#   expects when running via Docker Compose and deploying via GitHub Actions.
#
# How to use it:
# - Copy this file to `.env` at the project root and fill in your own values:
#     cp .env.example .env
#
# Important:
# - `.env` is gitignored and MUST NEVER be committed under any circumstances.
#
# Oracle Cloud (M5 / DevOps only):
# - ORACLE_HOST and ORACLE_SSH_KEY are only required for the DevOps deployment
#   workflow (Oracle Cloud Free Tier VM). All other teammates leave them blank.
# - ORACLE_SSH_KEY is a private key and must live only in GitHub Actions Secrets.
#
# LLM keys:
# - The LLM key variables accept a comma-separated list of keys (one per team
#   member). Locally, each person can put only their own single key.
# - The full combined list lives only in GitHub Actions Secrets.
#
# Naming:
# - These variable names MUST match GitHub Actions Secrets exactly.
# ==============================================================================


# --- ORACLE CLOUD (DevOps member only — M5) ---
# Public IP address (or DNS) of the Oracle Cloud Free Tier VM used for deployment.
ORACLE_HOST=
# Private SSH key used by GitHub Actions to SSH into the Oracle VM (leave blank locally).
ORACLE_SSH_KEY=


# --- LLM API KEYS ---
# Gemini 1.5 Flash — primary reasoning and Urdu (get from aistudio.google.com).
# Accepts comma-separated keys in CI; locally you can set just your own key.
GEMINI_API_KEYS=
# Groq Llama 3.1 8B — fast extraction and Whisper STT (get from console.groq.com).
# Accepts comma-separated keys in CI; locally you can set just your own key.
GROQ_API_KEYS=
# Together AI Mistral 7B — overflow fallback (get from api.together.xyz).
# Accepts comma-separated keys in CI; locally you can set just your own key.
TOGETHER_API_KEYS=
# OpenRouter — last resort fallback (get from openrouter.ai).
# Accepts comma-separated keys in CI; locally you can set just your own key.
OPENROUTER_API_KEYS=


# --- DATABASE ---
# Production database password for PostgreSQL 16 (choose a strong value locally).
POSTGRES_PASSWORD=


# --- AUTHENTICATION ---
# JWT signing secret used by the FastAPI backend (use a long random value locally).
JWT_SECRET=


# --- TWILIO ---
# Twilio Account SID (get from the Twilio Console).
TWILIO_ACCOUNT_SID=
# Twilio Auth Token (get from the Twilio Console).
TWILIO_AUTH_TOKEN=


# ==============================================================================
# Reference: docker-compose.prod.yml uses environment variables via ${} syntax
# (never hardcoded). Example:
#
# environment:
#   - GEMINI_API_KEYS=${GEMINI_API_KEYS}
#   - GROQ_API_KEYS=${GROQ_API_KEYS}
#   - TOGETHER_API_KEYS=${TOGETHER_API_KEYS}
#   - OPENROUTER_API_KEYS=${OPENROUTER_API_KEYS}
#   - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
#   - JWT_SECRET=${JWT_SECRET}
#   - TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
#   - TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}
# ==============================================================================
